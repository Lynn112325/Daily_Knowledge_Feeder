<div x-show="sidebarOpen" x-transition.opacity class="fixed inset-0 bg-slate-900/80 z-40 md:hidden"
    @click="sidebarOpen = false" x-cloak></div>

<aside
    class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 text-white flex flex-col transition-transform duration-300 ease-in-out md:relative md:translate-x-0"
    :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">

    <div class="flex items-center justify-between h-16 px-6 shrink-0 border-b border-slate-800">
        <a href="/"
            class="text-xl font-bold bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent whitespace-nowrap">
            📖 KnowledgeFeeder
        </a>
    </div>

    <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
        <a href="/"
            class="group flex items-center px-3 py-2 rounded-lg transition-all duration-200 <%= title === 'Dashboard' ? 'bg-blue-600/10 text-blue-400 font-bold' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %>">
            Dashboard
        </a>

        <a href="/articles"
            class="group flex items-center px-3 py-2 rounded-lg transition-all duration-200 <%= title === 'All Articles' ? 'bg-blue-600/10 text-blue-400 font-bold' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %>">
            Articles
        </a>

        <div class="pt-4 pb-2 px-3">
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Crawler System</span>
        </div>

        <a href="/crawler"
            class="group flex items-center px-3 py-2 rounded-lg transition-all duration-200 <%= title === 'Crawler Management' ? 'bg-blue-600/10 text-blue-400 font-bold' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %>">
            Sources
        </a>

        <a href="/tasks"
            class="group flex items-center px-3 py-2 rounded-lg transition-all duration-200 <%= title === 'Execution Logs' ? 'bg-blue-600/10 text-blue-400 font-bold' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %>">
            Task Logs
        </a>
    </nav>

</aside>