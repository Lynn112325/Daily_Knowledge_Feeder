<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'KnowledgeFeeder' %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="https://unpkg.com/ansi_up@5.2.1/ansi_up.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <% if (typeof needEditor !=='undefined' && needEditor) { %>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vditor/dist/index.css" />
        <script src="https://cdn.jsdelivr.net/npm/vditor/dist/index.min.js"></script>
        <% } %>

</head>

<body class="bg-slate-50 text-slate-900 font-sans h-screen flex overflow-hidden" x-data="{ sidebarOpen: false }">

    <%- include('sidebar') %>

        <div class="flex-1 flex flex-col min-w-0">
            <header
                class="md:hidden flex items-center justify-between bg-slate-900 text-white h-16 px-4 shrink-0 shadow-md">
                <a href="/"
                    class="text-lg font-bold bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent whitespace-nowrap">
                    📖 KnowledgeFeeder
                </a>
                <button @click="sidebarOpen = true" class="text-slate-300 hover:text-white">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </header>

            <main class="flex-1 p-6 md:p-8 overflow-y-auto flex flex-col">
                <div class="flex-1 max-w-7xl w-full mx-auto">
                    <%- include('breadcrumb') %>