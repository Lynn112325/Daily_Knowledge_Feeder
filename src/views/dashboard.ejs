<%- include('partials/header', { title: 'Dashboard' }) %>
    <div class="max-w-7xl mx-auto px-4">
        <% if (pendingInitCount> 0) { %>
            <div
                class="mb-8 bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-xl shadow-sm flex items-center justify-between">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd"
                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-amber-700">
                            You have <span class="font-bold">
                                <%= pendingInitCount %>
                            </span> sources pending initialization.
                        </p>
                    </div>
                </div>
                <a href="/crawler?autoInit=true"
                    class="ml-auto bg-amber-600 text-white px-4 py-2 rounded-lg text-xs font-bold hover:bg-amber-700 transition">
                    Jump to Fix Now
                </a>
            </div>
            <% } %>
                <h1 class="text-2xl font-bold mb-6 text-slate-800">Overview</h1>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <p class="text-sm text-slate-500 mb-1">Total Articles</p>
                        <div class="flex items-baseline gap-2">
                            <p class="text-3xl font-bold text-slate-900">
                                <%= stats.totalArticles %>
                            </p>
                            <span class="text-xs text-slate-400">items</span>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <p class="text-sm text-slate-500 mb-1 font-normal">Scraped Today</p>
                        <p class="text-3xl font-bold text-emerald-600">
                            +<%= stats.todayCount %>
                        </p>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <p class="text-sm text-slate-500 mb-1">Sources Syncing</p>
                        <div class="flex items-center gap-2">
                            <p class="text-3xl font-bold text-slate-900">
                                <%= stats.activeSources %>
                            </p>
                            <p class="text-sm text-slate-400 mt-2">/ <%= stats.totalSources %>
                            </p>
                            <span class="flex h-2 w-2 ml-auto">
                                <span
                                    class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-emerald-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                            </span>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <p class="text-sm text-slate-500 mb-1">Read Completed</p>
                        <div class="flex items-baseline gap-2 text-blue-600">
                            <p class="text-3xl font-bold">
                                <%= stats.readCount %>
                            </p>
                            <span class="text-xs font-medium opacity-80">
                                (<%= Math.round((stats.readCount / stats.totalArticles) * 100) %>%)
                            </span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h2 class="text-lg font-bold text-slate-800 flex items-center">
                                <span class="flex h-3 w-3 mr-3">
                                    <span
                                        class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-emerald-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                                </span>
                                Reading Now
                                <span
                                    class="ml-2 px-2 py-0.5 text-xs font-normal bg-slate-100 text-slate-500 rounded-md">
                                    <%= readingArticles.length %>
                                </span>
                            </h2>
                            <a href="/articles" class="text-xs text-blue-500 hover:text-blue-700 font-medium">View
                                All</a>
                        </div>

                        <div class="space-y-4">
                            <% if (readingArticles && readingArticles.length> 0) { %>
                                <% readingArticles.forEach((article, index)=> { %>
                                    <a href="/articles/<%= article._id %>"
                                        class="flex items-center justify-between p-2 -mx-2 rounded-lg hover:bg-slate-50 group transition-all">
                                        <div class="flex items-center truncate mr-4">
                                            <span class="text-xs font-mono text-slate-300 mr-3 w-4">
                                                <%= index + 1 %>
                                            </span>
                                            <div class="truncate">
                                                <span
                                                    class="text-sm font-medium text-slate-700 group-hover:text-blue-600 transition">
                                                    <%= article.title %>
                                                </span>
                                                <p class="text-xs text-slate-400 mt-1">
                                                    Active for <%= dateHelper.daysSince(article.updatedAt) %> days
                                                </p>
                                            </div>
                                        </div>
                                        <svg class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-colors"
                                            fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </a>
                                    <% }) %>
                                        <% } else { %>
                                            <p class="text-sm text-slate-400 italic text-center py-4">No active
                                                readings.</p>
                                            <% } %>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h2 class="text-lg font-bold text-slate-800 flex items-center">
                                <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                Read Later Queue
                                <span
                                    class="ml-2 px-2 py-0.5 text-xs font-normal bg-slate-100 text-slate-500 rounded-md">
                                    <%= laterArticles.length %>
                                </span>
                            </h2>
                            <a href="/articles?status=later"
                                class="text-xs text-blue-500 hover:text-blue-700 font-medium">Manage Queue</a>
                        </div>

                        <div class="space-y-4">
                            <% if (laterArticles && laterArticles.length> 0) { %>
                                <% laterArticles.forEach((article, index)=> { %>
                                    <a href="/articles/<%= article._id %>"
                                        class="flex items-center justify-between p-2 -mx-2 rounded-lg hover:bg-slate-50 group transition-all">
                                        <div class="flex items-center truncate mr-4">
                                            <span class="text-xs font-mono text-slate-300 mr-3 w-4">
                                                <%= index + 1 %>
                                            </span>
                                            <div class="truncate">
                                                <span
                                                    class="text-sm font-medium text-slate-700 group-hover:text-blue-600 transition">
                                                    <%= article.title %>
                                                </span>
                                                <p class="text-xs text-slate-400 mt-1">
                                                    Added <%= dateHelper.fromNow(article.createdAt) %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <svg class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-colors"
                                                fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round"
                                                    stroke-linejoin="round" stroke-width="2"></path>
                                                <path
                                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                                    stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                                </path>
                                            </svg>
                                        </div>
                                    </a>
                                    <% }) %>
                                        <% } else { %>
                                            <p class="text-sm text-slate-400 italic text-center py-4">Queue is empty.
                                            </p>
                                            <% } %>
                        </div>
                    </div>
                </div>
    </div>
    <%- include('partials/footer.ejs') %>