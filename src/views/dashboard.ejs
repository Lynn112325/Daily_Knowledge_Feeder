<%- include('partials/header', { title: 'Dashboard' }) %>
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-2xl font-bold mb-6 text-slate-800">System Overview</h1>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                <p class="text-sm text-slate-500 mb-1">Total Articles</p>
                <p class="text-3xl font-bold text-slate-900">
                    <%= stats.totalArticles %>
                </p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 text-emerald-600">
                <p class="text-sm text-slate-500 mb-1 font-normal">Scraped Today</p>
                <p class="text-3xl font-bold">+<%= stats.todayCount %>
                </p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                <p class="text-sm text-slate-500 mb-1">Sources Syncing</p>
                <p class="text-3xl font-bold">
                    <%= stats.activeSources %>
                </p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                <p class="text-sm text-slate-500 mb-1">DB Size</p>
                <p class="text-3xl font-bold text-blue-600">84MB</p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="font-bold mb-4">Quick Start</h3>
            <div class="flex gap-4">
                <a href="/crawler/backfill" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">New
                    Crawl
                    Mission</a>
                <a href="/articles" class="border border-slate-200 px-4 py-2 rounded-lg hover:bg-slate-50">Review
                    Content</a>
            </div>
        </div>
    </div>
    <%- include('partials/footer.ejs') %>