<%- include('partials/header', { title: 'Article View / Edit' }) %>
  <div id="vditor"></div>
  <div id="tooltip"></div>

  <script src="/js/articleActions.js"></script>
  <script src="/js/dictionaryAction.js"></script>
  <script>
    const tooltip = document.getElementById('tooltip');

    // 1. Get the Markdown text from Express
    const initialContent = <%-  JSON.stringify(initialMarkdown) %>;

    // 2. Get the Unique ID from Express
    const currentArticleId = <%- JSON.stringify(articleId) %>;

    const vditor = new Vditor('vditor', {
      height: '100%',
      mode: 'ir',
      value: initialContent,
      placeholder: 'Loading contents...',
      theme: 'classic',
      counter: {
        enable: true
      },
      preview: {
        markdown: {
          mark: true,
          toc: true,
          footnotes: true,
        },
        render: {
          media: {
            enable: true
          }
        }
      },
      image: {
        isPreview: true,
      },
      link: {
        isOpen: true,
        click: (element) => {
          let url = typeof element === 'string'
            ? element
            : (element.innerText || element.textContent);

          if (url && url.startsWith('http')) {
            window.open(url, '_blank');
          } else {
            console.warn("Clicked element is not a valid URL:", url);
          }
        }
      },
      cache: {
        enable: true,
        // enable: false,
        id: `vditor-${currentArticleId}`,
      },
      toolbarConfig: {
        pin: true,
      },
      toolbar: [
        "emoji",
        "headings",
        "bold",
        "italic",
        "strike",
        "link",
        {
          name: 'highlight',
          tip: 'highlight',
          hotkey: "⌘H",
          tipPosition: "ne",
          icon: '<svg viewBox="0 0 1024 1024"><path d="M793.8 131.2L157.6 767.4l-26.4 125.4 125.4-26.4L892.8 230.2l-99-99z"></path></svg>',
          click(event) {
            event.preventDefault();
            event.stopPropagation();

            // 1. Get selected text
            const selectedText = vditor.getSelection();
            if (!selectedText) return;

            // 2. Get full markdown content
            const fullMarkdown = vditor.getValue();

            // 3. Define the wrapped pattern
            const wrappedPattern = `==${selectedText}==`;

            // 4. Toggle highlight logic
            if (fullMarkdown.includes(wrappedPattern)) {
              // Remove tags: delete selection and insert plain text
              vditor.deleteValue();
              vditor.insertValue(selectedText);
            } else {
              // Add tags: wrap selection with ==
              vditor.updateValue(`==${selectedText}==`);
            }
          }
        },
        '|',
        "list",
        "ordered-list",
        "check",
        "outdent",
        "indent",
        "|",
        "quote",
        "line",
        "code",
        "inline-code",
        "insert-before",
        "insert-after",
        "|",
        "table",
        'export',
        "|",
        "undo",
        "redo",
        "|",
        "fullscreen",
        {
          name: "more",
          toolbar: [
            "outline",
            "preview",
            "devtools",
            "info",
            "help",
          ],
        },
      ],
      after: () => {
        console.log("vditor ready.");
      }
    });

    const articleId = currentArticleId;

    function handleUpdateClick() {
      updateStatus(currentArticleId);
    }

    function handleSaveClick(content) {
      saveToDB(content);
    }

    // Listen for all click events on the document
    document.addEventListener('click', async (e) => {
        // Find the closest anchor (<a>) tag from the clicked element
        const link = e.target.closest('a');

        // Skip if: 
        // 1. No link was clicked
        // 2. Link opens in a new tab (_blank)
        // 3. Link is a javascript action (e.g., javascript:void(0))
        if (!link || link.target === '_blank' || link.href.includes('javascript:')) return;

        const destination = link.href;

        // Skip if the link is just an anchor/hash jump on the same page
        if (destination.startsWith(window.location.origin + window.location.pathname + '#')) return;

        // Prevent the default browser navigation
        e.preventDefault();

        // Show a confirmation dialog using SweetAlert2
        const result = await Swal.fire({
            title: 'Save changes?',
            text: 'You are leaving this page. Do you want to sync your changes to the database first?',
            icon: 'question',
            showDenyButton: true,
            showCancelButton: true,
            confirmButtonText: 'Save & Exit',
            denyButtonText: 'Exit without saving',
            cancelButtonText: 'Stay here',
            confirmButtonColor: '#3085d6',
            denyButtonColor: '#d33',
        });

        // Handle user choices
        if (result.isConfirmed) {
            // User clicked "Save & Exit"
            const currentContent = vditor.getValue();
            try {
                await saveToDB(currentContent); // Wait for the database sync
                window.location.href = destination; // Navigate after success
            } catch (err) {
                console.error("Navigation halted due to save error.");
            }
        } else if (result.isDenied) {
            // User clicked "Exit without saving"
            window.location.href = destination; // Navigate immediately
        }
        // If user clicked "Stay here" (Cancel), do nothing and remain on the page
    });

  </script>
  <div class="fab-container">
    <div class="fab-item" onclick="handleUpdateClick()" title="Update Status">
      <span class="fab-label">Update Status</span>
      <div class="fab-icon status-icon" style="background: #6366f1;"> <svg viewBox="0 0 1024 1024">
          <path
            d="M912 192H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z m0 256H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z m0 256H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z">
          </path>
        </svg>
      </div>
    </div>

    <div class="fab-item" onclick="handleSaveClick(vditor.getValue())" title="Save to Database">
      <span class="fab-label">Save</span>
      <div class="fab-icon save-icon">
        <svg viewBox="0 0 1024 1024">
          <path
            d="M893.3 293.3L730.7 130.7c-7.5-7.5-16.7-13-26.7-16V128H128v768h768V320c0-10-2.5-19.2-6.7-26.7zM448 192h128v128H448V192z m320 576H256V576h512v192z">
          </path>
        </svg>
      </div>
    </div>

    <div class="fab-main">
      <div class="fab-icon main-icon">＋</div>
    </div>
  </div>
  <%- include('partials/footer.ejs') %>