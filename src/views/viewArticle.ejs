<%- include('partials/header', { title: 'Article View / Edit' }) %>
  <div id="vditor"></div>
  <div id="tooltip"></div>
  <script src="/js/articleActions.js"></script>
  <script>
    const tooltip = document.getElementById('tooltip');

    // 1. Get the Markdown text from Express
    const initialContent = <%-  JSON.stringify(initialMarkdown) %>;

    // 2. Get the Unique ID from Express
    const currentArticleId = <%- JSON.stringify(articleId) %>;

    const vditor = new Vditor('vditor', {
      height: '100%',
      mode: 'ir',
      value: initialContent,
      placeholder: 'Loading contents...',
      theme: 'classic',
      counter: {
        enable: true
      },
      preview: {
        markdown: {
          mark: true,
          toc: true,
          footnotes: true,
        },
        render: {
          media: {
            enable: true
          }
        }
      },
      image: {
        isPreview: true,
      },
      link: {
        isOpen: true,
        click: (element) => {
          let url = typeof element === 'string'
            ? element
            : (element.innerText || element.textContent);

          if (url && url.startsWith('http')) {
            window.open(url, '_blank');
          } else {
            console.warn("Clicked element is not a valid URL:", url);
          }
        }
      },
      cache: {
        enable: true,
        // enable: false,
        id: `vditor-${currentArticleId}`,
      },
      toolbarConfig: {
        pin: true,
      },
      toolbar: [
        "emoji",
        "headings",
        "bold",
        "italic",
        "strike",
        "link",
        {
          name: 'highlight',
          tip: 'highlight',
          hotkey: "⌘H",
          tipPosition: "ne",
          icon: '<svg viewBox="0 0 1024 1024"><path d="M793.8 131.2L157.6 767.4l-26.4 125.4 125.4-26.4L892.8 230.2l-99-99z"></path></svg>',
          click(event) {
            event.preventDefault();
            event.stopPropagation();

            // 1. Get selected text
            const selectedText = vditor.getSelection();
            if (!selectedText) return;

            // 2. Get full markdown content
            const fullMarkdown = vditor.getValue();

            // 3. Define the wrapped pattern
            const wrappedPattern = `==${selectedText}==`;

            // 4. Toggle highlight logic
            if (fullMarkdown.includes(wrappedPattern)) {
              // Remove tags: delete selection and insert plain text
              vditor.deleteValue();
              vditor.insertValue(selectedText);
            } else {
              // Add tags: wrap selection with ==
              vditor.updateValue(`==${selectedText}==`);
            }
          }
        },
        '|',
        "list",
        "ordered-list",
        "check",
        "outdent",
        "indent",
        "|",
        "quote",
        "line",
        "code",
        "inline-code",
        "insert-before",
        "insert-after",
        "|",
        "table",
        'export',
        "|",
        "undo",
        "redo",
        "|",
        "fullscreen",
        {
          name: "more",
          toolbar: [
            "outline",
            "preview",
            "devtools",
            "info",
            "help",
          ],
        },
      ],
      after: () => {
        console.log("vditor ready.");
      }
    });

    tooltip.addEventListener('mousedown', (e) => e.stopPropagation());
    tooltip.addEventListener('mouseup', (e) => e.stopPropagation());
    /**
     * Converts dictionary translation strings with newlines into HTML format
     */
    function formatTranslation(translation) {
      if (!translation) return '';
      return translation
        .trim()
        .split('\n')
        .filter(line => line.trim() !== '')
        .map(line => `<div style="margin-bottom: 2px;">${line}</div>`)
        .join('');
    }

    /**
     * Speech synthesis using Google Translate TTS
     */
    function speak(text) {
      const maxLength = 200;

      // 1. Check text length and show alert if it exceeds the limit
      if (text.length > maxLength) {
        Swal.fire({
          icon: 'warning',
          title: 'Text too long',
          text: `Google TTS limit is ${maxLength} characters. Only the first part will be read.`,
          toast: true,
          position: 'top-end',
          timer: 3000,
          showConfirmButton: false
        });
      }

      const safeText = text.substring(0, maxLength);

      // 2. Build Google TTS URL
      // 'client=tw-ob' is used to bypass API key requirements
      const url = `https://translate.google.com/translate_tts?ie=UTF-8&q=${encodeURIComponent(safeText)}&tl=en&client=tw-ob`;

      // 3. Audio playback logic
      const audio = new Audio(url);
      
      // Stop any currently playing audio
      if (window.currentAudio) {
        window.currentAudio.pause();
        window.currentAudio.currentTime = 0;
      }
      
      window.currentAudio = audio;

      audio.play().catch(err => {
        console.error("Google TTS playback failed:", err);
        Swal.fire('Playback Error', 'Could not play audio. Please check your connection.', 'error');
      });
    }

    /**
     * Automatically expands the selection to full word boundaries
     * (Includes periods, numbers, and hyphens)
     */
    function expandSelectionToWord() {
      const sel = window.getSelection();
      if (sel.rangeCount === 0 || sel.isCollapsed) return '';
      let range = sel.getRangeAt(0).cloneRange();

      const startNode = range.startContainer;
      const endNode = range.endContainer;

      // Validate that the selection is within text nodes
      if (range.startContainer.nodeType !== Node.TEXT_NODE ||
        range.endContainer.nodeType !== Node.TEXT_NODE) {
        return sel.toString().trim();
      }

      // Define characters allowed within a word boundary
      const isNotWordChar = /[^a-zA-Z0-9.-]/;

      // 1. Expand start position backward (Left)
      while (range.startOffset > 0) {
        const nextStart = range.startOffset - 1;
        range.setStart(startNode, nextStart);

        const text = range.toString();
        if (isNotWordChar.test(text[0])) {
          range.setStart(startNode, nextStart + 1);
          break;
        }
      }

      // 2. Expand end position forward (Right)
      while (range.endOffset < endNode.length) {
        const nextEnd = range.endOffset + 1;
        if (nextEnd <= endNode.length) {
          range.setEnd(endNode, nextEnd);
        } else {
          break;
        }

        const text = range.toString();
        if (isNotWordChar.test(text[text.length - 1])) {
          range.setEnd(endNode, nextEnd - 1);
          break;
        }
      }

      // 3. Clean up: Shrink selection to exclude leading/trailing symbols
      let currentText = range.toString();

      while (currentText.length > 0 && isNotWordChar.test(currentText[0])) {
        const nextStart = range.startOffset + 1;
        if (nextStart <= startNode.length) {
          range.setStart(startNode, nextStart);
          currentText = range.toString();
        } else {
          break;
        }
      }

      while (currentText.length > 0 && isNotWordChar.test(currentText[currentText.length - 1])) {
        const nextEnd = range.endOffset - 1;
        if (nextEnd >= 0) {
          range.setEnd(endNode, nextEnd);
          currentText = range.toString();
        } else {
          break;
        }
      }

      // Apply the expanded range to the UI selection
      sel.removeAllRanges();
      sel.addRange(range);

      return currentText.trim();
    }

    /**
     * Dictionary lookup and TTS logic
     */
    document.getElementById('vditor').addEventListener('mouseup', async (e) => {
      // Ignore clicks on hyperlinks
      if (e.target.closest('a')) return;

      const selection = expandSelectionToWord();

      // Regex to match valid words or sentences (supporting special chars like ° and smart quotes)
      const validRegex = /^[a-zA-Z0-9\s\u00A0,.'’":;?!()°/ \-]{2,}$/;

      if (selection && validRegex.test(selection)) {
        const isSentence = selection.includes(' ');

        // Escape quotes to prevent JavaScript errors in HTML event attributes
        const safeSelection = selection
          .replace(/'/g, "\\'")
          .replace(/’/g, "\\'")
          .replace(/\n/g, " ");

        if (!isSentence) {
          // --- Single Word Mode ---
          try {
            const response = await fetch(`/api/dictionary/${selection}`);
            const data = await response.json();

            if (data.success) {
              const dict = data.data;
              const translationHtml = formatTranslation(dict.translation);

              tooltip.innerHTML = `
                        <div style="display:flex; align-items:center; gap:8px;">
                            <b style="color:#fbbf24; font-size:16px;">${dict.word}</b>
                            <button onclick="speak('${safeSelection}')" 
                                    style="background:none; border:none; cursor:pointer; color:#9ca3af; padding:0; font-size:16px;" 
                                    title="Play pronunciation">🔊</button>
                        </div>
                        <div style="font-size:12px; color:#9ca3af; margin:5px 0;">Collins: ${dict.collins || 0}★</div>
                        <div style="font-size:13px; line-height:1.4;">${translationHtml}</div>
                    `;
            }
          } catch (err) {
            console.error("Dictionary API error:", err);
          }
        } else {
          // --- Sentence Mode ---
          tooltip.innerHTML = `
                <div style="display:flex; align-items:center; gap:8px; padding: 4px 0;">
                    <span style="color:#9ca3af; font-size:12px;">Sentence</span>
                    <button onclick="speak('${safeSelection}')" 
                            style="background:#fbbf24; border:none; border-radius:4px; color:#1e293b; padding:2px 8px; cursor:pointer; font-size:12px; font-weight:bold;">
                        🔊 Play Audio
                    </button>
                </div>
            `;
        }

        // Positioning the tooltip near the cursor
        tooltip.style.left = e.clientX + 15 + 'px';
        tooltip.style.top = e.clientY + 15 + 'px';
        tooltip.style.display = 'block';
      }
    });

    /**
     * Global click listener to close tooltip
     */
    document.addEventListener('mousedown', (e) => {
      if (e.target.closest('a')) return;
      if (!tooltip.contains(e.target)) tooltip.style.display = 'none';
    });

    const articleId = currentArticleId;

    function handleUpdateClick() {
      updateStatus(currentArticleId);
    }

    function handleSaveClick(content) {
      saveToDB(content);
    }

  </script>
  <div class="fab-container">
    <div class="fab-item" onclick="handleUpdateClick()" title="Update Status">
      <span class="fab-label">Update Status</span>
      <div class="fab-icon status-icon" style="background: #6366f1;"> <svg viewBox="0 0 1024 1024">
          <path
            d="M912 192H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z m0 256H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z m0 256H112c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16h800c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16z">
          </path>
        </svg>
      </div>
    </div>

    <div class="fab-item" onclick="handleSaveClick(vditor.getValue())" title="Save to Database">
      <span class="fab-label">Save</span>
      <div class="fab-icon save-icon">
        <svg viewBox="0 0 1024 1024">
          <path
            d="M893.3 293.3L730.7 130.7c-7.5-7.5-16.7-13-26.7-16V128H128v768h768V320c0-10-2.5-19.2-6.7-26.7zM448 192h128v128H448V192z m320 576H256V576h512v192z">
          </path>
        </svg>
      </div>
    </div>

    <div class="fab-main">
      <div class="fab-icon main-icon">＋</div>
    </div>
  </div>
  <%- include('partials/footer.ejs') %>